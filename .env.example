NEXT_PUBLIC_SITE_URL=https://phim.bluesia.net
OPHIM_BASE_URL=https://ophim1.com
NEXT_PUBLIC_IMAGE_CACHE_URL=https://img.bluesia.net
IMAGE_CACHE_SIGNING_SECRET=
IMAGE_SIGNATURE_VERSION=v1

# Optional embed providers. Keep these unset to use app defaults.
# VSEMBED_EMBED_BASE_URL=https://vsembed.ru
# VSEMBED_MOBILE_EMBED_HOST=vsembed.su

# External signed image-cache contract:
# https://img.bluesia.net/i/m/<sha256-normalized-upstream-url>.webp?url=<encoded-normalized-upstream-image-url>&sig=v1.<hmac-sha256-hex>
# https://img.bluesia.net/i/d/<sha256-normalized-upstream-url>.webp?url=<encoded-normalized-upstream-image-url>&sig=v1.<hmac-sha256-hex>
# IMAGE_CACHE_SIGNING_SECRET is server-only. Never prefix it with NEXT_PUBLIC_.
# Signing is only done for trusted OPhim server-side movie data, never arbitrary client input.
# Legacy /image?url= is VPS compatibility only and still requires sig; new frontend code must not generate it.
