OPHIM_BASE_URL=https://ophim1.com
NEXT_PUBLIC_IMAGE_CACHE_URL=https://img.bluesia.net

# Optional embed providers. Keep these unset to use app defaults.
# VSEMBED_EMBED_BASE_URL=https://vsembed.ru
# VSEMBED_MOBILE_EMBED_HOST=vsembed.su

# External image-cache contract:
# https://img.bluesia.net/i/m/<sha256-normalized-upstream-url>.webp?url=<encoded-normalized-upstream-image-url>
# https://img.bluesia.net/i/d/<sha256-normalized-upstream-url>.webp?url=<encoded-normalized-upstream-image-url>
# Legacy /image?url= is VPS compatibility only; new frontend code must not generate it.
